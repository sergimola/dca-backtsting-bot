{
  "name": "@dca-bot/api-layer",
  "version": "0.1.0",
  "description": "Express/TypeScript HTTP API service for DCA backtesting",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-esm src/main.ts",
    "start": "node dist/main.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist coverage"
  },
  "keywords": [
    "backtest",
    "dca",
    "trading",
    "typescript",
    "express"
  ],
  "author": "DCA Bot Team",
  "license": "ISC",
  "dependencies": {
    "decimal.js": "^10.4.3",
    "express": "^5.2.1",
    "ndjson": "^2.0.0",
    "pino": "^10.3.1",
    "split2": "^4.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/ndjson": "^2.0.1",
    "@types/node": "^25.3.5",
    "@types/split2": "^4.2.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
